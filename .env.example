# ─── Google Cloud Configuration ──────────────────────────────────────────────
# Your GCP project ID (must match the project used in deploy.sh)
GOOGLE_CLOUD_PROJECT_ID=

# Pub/Sub topic name for event ingestion (created by Terraform)
PUBSUB_TOPIC_NAME=tracer-events

# ─── Tracer SDK Authentication ───────────────────────────────────────────────
# API key the SDK uses to authenticate with the ingestion endpoint
# Generate any random string, e.g.: openssl rand -hex 16
TRACER_API_KEY=tk_dev_local

# ─── Dashboard Auth ──────────────────────────────────────────────────────────
# Password to access the /tracer developer dashboard
TRACER_DEMO_PASSWORD=tracer-demo

# ─── Public (exposed to browser) ────────────────────────────────────────────
# These are safe to expose — they identify the project but don't grant admin access
NEXT_PUBLIC_PROJECT_ID=tracer-demo
NEXT_PUBLIC_TRACER_API_KEY=tk_dev_local
NEXT_PUBLIC_TRACER_API_KEY_DISPLAY=tk_dev_local
